{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dashboard-01",
  "type": "registry:block",
  "title": "Dashboard 01",
  "description": "A dashboard composition skeleton: page layout wiring the sidebar shell, header, metric row, chart panel, and data table via standalone block items.",
  "categories": ["screen:dashboard", "intent:monitor", "density:high"],
  "registryDependencies": [
    "badge",
    "button",
    "card",
    "chart",
    "checkbox",
    "drawer",
    "dropdown-menu",
    "input",
    "label",
    "select",
    "separator",
    "sidebar",
    "table",
    "tabs",
    "toggle-group"
  ],
  "files": [
    {
      "path": "app/dashboard-01/page.tsx",
      "type": "registry:page",
      "target": "app/dashboard-01/page.tsx"
    },
    {
      "path": "app/dashboard-01/data.json",
      "type": "registry:file",
      "target": "app/dashboard-01/data.json"
    },
    {
      "path": "components/dashboard-01/app-sidebar.tsx",
      "type": "registry:component"
    },
    {
      "path": "components/dashboard-01/nav-main.tsx",
      "type": "registry:component"
    },
    {
      "path": "components/dashboard-01/nav-user.tsx",
      "type": "registry:component"
    },
    {
      "path": "components/nav-documents.tsx",
      "type": "registry:component"
    },
    {
      "path": "components/nav-secondary.tsx",
      "type": "registry:component"
    }
  ],
  "meta": {
    "aiDesignSystem": {
      "assetKind": "screen-pattern",
      "maturity": "experimental",
      "source": "official-shadcn",
      "screenType": "dashboard",
      "blockRoles": [
        "app-shell-sidebar",
        "page-header-actions",
        "summary-metric-row",
        "chart-panel",
        "data-table-panel"
      ],
      "userIntents": ["monitor", "analyze", "browse"],
      "jobMapStages": ["monitor"],
      "dataShapes": ["metric", "time-series", "collection"],
      "interactionModels": [
        "read-only",
        "filter-sort",
        "selection-multiple",
        "drawer-inspection",
        "drag-drop"
      ],
      "layoutModel": {
        "shell": "sidebar",
        "region": "full-page",
        "responsive": ["mobile", "desktop"]
      },
      "density": "high",
      "stateCoverage": ["default", "loading", "empty", "error", "mobile"],
      "accessibility": {
        "keyboard": true,
        "focusVisible": true,
        "labels": true,
        "contrastChecked": false,
        "rtl": false,
        "i18n": false,
        "notes": "Keyboard/focus behavior inherited from shadcn primitives (table, drawer, dropdown). Not independently audited."
      },
      "dependencies": {
        "shadcn": [
          "badge",
          "button",
          "card",
          "chart",
          "checkbox",
          "drawer",
          "dropdown-menu",
          "input",
          "label",
          "select",
          "separator",
          "sidebar",
          "table",
          "tabs",
          "toggle-group"
        ],
        "npm": [
          "@tanstack/react-table",
          "@dnd-kit/core",
          "@dnd-kit/modifiers",
          "@dnd-kit/sortable",
          "@dnd-kit/utilities",
          "recharts",
          "sonner",
          "zod",
          "lucide-react"
        ],
        "registries": [
          "sidebar-07",
          "page-header-actions-01",
          "summary-metric-row-01",
          "chart-panel-01",
          "data-table-panel-01"
        ]
      },
      "composition": {
        "requiredBlocks": [
          "app-shell-sidebar",
          "page-header-actions",
          "summary-metric-row",
          "chart-panel",
          "data-table-panel"
        ],
        "optionalBlocks": ["filter-toolbar", "drawer-inspector"],
        "incompatibleWith": ["app-shell-topnav"]
      },
      "verification": {
        "storybookStories": [
          "patterns-dashboard-dashboard-01--default",
          "patterns-dashboard-dashboard-01--loading",
          "patterns-dashboard-dashboard-01--empty",
          "patterns-dashboard-dashboard-01--error"
        ],
        "interactionTests": false,
        "accessibilityTests": false,
        "visualSnapshots": false,
        "lintTypecheck": false
      },
      "evidence": {
        "sourceCount": 3,
        "confidence": "high",
        "verifiedAt": "2026-07-07",
        "sourceUrls": [
          "https://ui.shadcn.com/blocks",
          "https://ui.shadcn.com/docs/registry/registry-item-json"
        ]
      },
      "risk": {
        "level": "medium",
        "licenseReviewNeeded": false,
        "maintenanceReviewNeeded": false,
        "missingStates": ["permission-denied", "dark-mode", "rtl"],
        "notes": "RESOLVED 2026-07-08: former install collision with sidebar-07 (which owns app/dashboard/page.tsx and the shared app-sidebar/nav-main/nav-user) fixed by wiring this pattern to a dedicated route app/dashboard-01/ with its colliding components namespaced under components/dashboard-01/. Shared non-colliding components (site-header, section-cards, chart-area-interactive, data-table, nav-documents, nav-secondary) remain at components/. Sample data is static (app/dashboard-01/data.json); loading/empty/error states are simulated by DashboardScreen and evidenced in Storybook."
      },
      "extensions": {
        "localEvidence": [
          "app/dashboard-01/page.tsx",
          "app/dashboard-01/dashboard-screen.tsx",
          "components/dashboard-01/app-sidebar.tsx",
          "components/site-header.tsx",
          "components/section-cards.tsx",
          "components/chart-area-interactive.tsx",
          "components/data-table.tsx",
          "app/dashboard-01/data.json",
          "components/patterns/dashboard-01-screen.stories.tsx"
        ]
      }
    }
  }
}
