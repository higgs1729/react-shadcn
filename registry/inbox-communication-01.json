{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "inbox-communication-01",
  "type": "registry:block",
  "title": "Inbox Communication 01",
  "description": "A high-density human communication inbox for searching, filtering, assigning, and resolving incoming conversations.",
  "categories": ["screen:inbox-communication", "intent:communicate", "density:high"],
  "registryDependencies": ["alert", "badge", "button", "checkbox", "empty", "input-group", "select", "sidebar", "skeleton", "table", "toggle-group"],
  "files": [
    {
      "path": "app/inbox-communication-01/inbox-screen.tsx",
      "type": "registry:component",
      "target": "app/inbox-communication-01/inbox-screen.tsx"
    },
    {
      "path": "app/inbox-communication-01/data.json",
      "type": "registry:file",
      "target": "app/inbox-communication-01/data.json"
    }
  ],
  "meta": {
    "aiDesignSystem": {
      "assetKind": "screen-pattern",
      "maturity": "experimental",
      "source": "internal",
      "screenType": "inbox-communication",
      "blockRoles": ["app-shell-sidebar", "page-header-actions", "filter-toolbar", "data-table-panel"],
      "userIntents": ["communicate", "review", "monitor", "filter"],
      "jobMapStages": ["locate", "execute", "conclude"],
      "dataShapes": ["conversation", "collection"],
      "interactionModels": ["filter-sort", "selection-multiple", "multi-action", "real-time"],
      "layoutModel": {
        "shell": "sidebar",
        "region": "full-page",
        "responsive": ["mobile", "desktop"]
      },
      "density": "high",
      "stateCoverage": ["default", "loading", "empty", "error", "mobile", "dark-mode"],
      "accessibility": {
        "keyboard": true,
        "focusVisible": true,
        "labels": true,
        "contrastChecked": false,
        "notes": "Interactive controls use labeled shadcn/base-ui primitives; the composed screen has not received an independent accessibility audit."
      },
      "dependencies": {
        "shadcn": ["alert", "badge", "button", "checkbox", "empty", "input-group", "select", "sidebar", "skeleton", "table", "toggle-group"],
        "npm": ["lucide-react"],
        "registries": ["sidebar-07", "page-header-actions-01", "filter-toolbar-01", "data-table-panel-01"]
      },
      "composition": {
        "requiredBlocks": ["app-shell-sidebar", "page-header-actions", "filter-toolbar", "data-table-panel"],
        "optionalBlocks": ["activity-feed", "comment-thread", "drawer-inspector", "notification-center"],
        "incompatibleWith": ["app-shell-topnav"]
      },
      "verification": {
        "storybookStories": [
          "patterns-inbox-communication-inbox-communication-01--default",
          "patterns-inbox-communication-inbox-communication-01--loading",
          "patterns-inbox-communication-inbox-communication-01--empty",
          "patterns-inbox-communication-inbox-communication-01--error"
        ],
        "interactionTests": false,
        "accessibilityTests": false,
        "visualSnapshots": false,
        "lintTypecheck": false
      },
      "evidence": {
        "sourceCount": 3,
        "confidence": "high",
        "verifiedAt": "2026-07-12",
        "sourceUrls": [
          "https://support.google.com/mail/answer/3094499",
          "https://www.intercom.com/help/en/articles/6258745-the-inbox-explained",
          "https://www.intercom.com/help/en/articles/6561699-assign-conversations-to-teammates-and-teams"
        ]
      },
      "risk": {
        "level": "medium",
        "licenseReviewNeeded": false,
        "maintenanceReviewNeeded": false,
        "missingStates": ["permission-denied", "offline", "rtl"],
        "notes": "Conversation data and real-time behavior are simulated locally; assignment, reply, snooze, and close actions are represented by the taxonomy but are not connected to a backend."
      },
      "extensions": {
        "localEvidence": [
          "app/inbox-communication-01/inbox-screen.tsx",
          "app/inbox-communication-01/data.json",
          "components/patterns/inbox-communication-01-screen.stories.tsx"
        ],
        "taxonomyDecision": "Human conversation triage has ownership and resolution lifecycle actions that collection lacks, without the AI delegation and token streaming central to conversation-assistant."
      }
    }
  }
}
