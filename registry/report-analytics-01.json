{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "report-analytics-01",
  "type": "registry:block",
  "title": "Report Analytics 01",
  "description": "A historical revenue report combining a period filter, a KPI metric row, a trend chart, and a detailed data table for deep analysis.",
  "categories": ["screen:report-analytics", "intent:analyze", "density:high"],
  "registryDependencies": ["alert", "badge", "button", "card", "chart", "checkbox", "drawer", "dropdown-menu", "empty", "input", "input-group", "label", "select", "separator", "sidebar", "skeleton", "table", "tabs", "toggle-group"],
  "files": [
    {
      "path": "app/(system)/report-analytics-01/report-analytics-screen.tsx",
      "type": "registry:component",
      "target": "app/(system)/report-analytics-01/report-analytics-screen.tsx"
    },
    {
      "path": "app/(system)/report-analytics-01/data.json",
      "type": "registry:file",
      "target": "app/(system)/report-analytics-01/data.json"
    }
  ],
  "meta": {
    "aiDesignSystem": {
      "assetKind": "screen-pattern",
      "maturity": "experimental",
      "source": "internal",
      "screenType": "report-analytics",
      "blockRoles": ["page-header-actions", "filter-toolbar", "summary-metric-row", "chart-panel", "data-table-panel"],
      "userIntents": ["analyze", "compare", "review"],
      "jobMapStages": ["conclude"],
      "dataShapes": ["metric", "time-series", "categorical", "collection"],
      "interactionModels": ["read-only", "filter-sort"],
      "layoutModel": {
        "shell": "none",
        "region": "full-page",
        "responsive": ["mobile", "desktop"]
      },
      "density": "high",
      "stateCoverage": ["default", "loading", "empty", "error"],
      "accessibility": {
        "keyboard": true,
        "focusVisible": true,
        "labels": true,
        "contrastChecked": false,
        "notes": "Composed from labelled shadcn/base-ui primitives (labelled search and period select, view toggle, data table). Chart and table behavior are inherited from the shadcn dashboard blocks; the composed screen has not received an independent accessibility audit."
      },
      "dependencies": {
        "shadcn": ["alert", "badge", "button", "card", "chart", "checkbox", "drawer", "dropdown-menu", "empty", "input", "input-group", "label", "select", "separator", "sidebar", "skeleton", "table", "tabs", "toggle-group"],
        "npm": ["@tanstack/react-table", "@dnd-kit/core", "@dnd-kit/modifiers", "@dnd-kit/sortable", "@dnd-kit/utilities", "recharts", "sonner", "zod", "lucide-react"],
        "registries": ["page-header-actions-01", "filter-toolbar-01", "summary-metric-row-01", "chart-panel-01", "data-table-panel-01"]
      },
      "composition": {
        "requiredBlocks": ["page-header-actions", "filter-toolbar", "summary-metric-row", "chart-panel", "data-table-panel"],
        "optionalBlocks": ["app-shell-topnav", "empty-state", "error-recovery", "loading-skeleton"],
        "incompatibleWith": []
      },
      "verification": {
        "storybookStories": [
          "patterns-report-analytics-report-analytics-01--default",
          "patterns-report-analytics-report-analytics-01--loading",
          "patterns-report-analytics-report-analytics-01--empty",
          "patterns-report-analytics-report-analytics-01--error"
        ],
        "interactionTests": false,
        "accessibilityTests": false,
        "visualSnapshots": false,
        "lintTypecheck": false
      },
      "evidence": {
        "sourceCount": 2,
        "confidence": "medium",
        "verifiedAt": "2026-07-12",
        "sourceUrls": [
          "https://www.nngroup.com/articles/dashboards-preattentive/",
          "https://m3.material.io/foundations/content-design/data-visualization"
        ]
      },
      "risk": {
        "level": "medium",
        "licenseReviewNeeded": false,
        "maintenanceReviewNeeded": false,
        "missingStates": ["permission-denied", "offline", "rtl", "overflow"],
        "notes": "Metrics, chart, and table are simulated locally using the shared dashboard-01 fixture. Period, search, and view controls are wired to local state and do not re-query or re-aggregate the fixture; there is no backend, export, or real-time transport."
      },
      "extensions": {
        "localEvidence": [
          "app/(system)/report-analytics-01/report-analytics-screen.tsx",
          "app/(system)/report-analytics-01/data.json",
          "components/patterns/report-analytics-01-screen.stories.tsx"
        ],
        "taxonomyDecision": "report-analytics is a historical, filter-driven readout for deep trend analysis with no real-time updates, distinct from dashboard (time-sensitive at-a-glance monitoring with a persistent nav shell and live data)."
      }
    }
  }
}
