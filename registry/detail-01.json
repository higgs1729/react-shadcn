{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "detail-01",
  "type": "registry:block",
  "title": "Detail 01",
  "description": "An entity detail page presenting one primary record with its fields, activity history, threaded comments, and approve/reject actions.",
  "categories": ["screen:detail", "intent:review", "density:medium"],
  "registryDependencies": ["alert", "avatar", "badge", "breadcrumb", "button", "button-group", "card", "empty", "field", "item", "separator", "sidebar", "skeleton", "textarea"],
  "files": [
    {
      "path": "app/(system)/detail-01/detail-screen.tsx",
      "type": "registry:component",
      "target": "app/(system)/detail-01/detail-screen.tsx"
    },
    {
      "path": "app/(system)/detail-01/data.json",
      "type": "registry:file",
      "target": "app/(system)/detail-01/data.json"
    }
  ],
  "meta": {
    "aiDesignSystem": {
      "assetKind": "screen-pattern",
      "maturity": "experimental",
      "source": "internal",
      "screenType": "detail",
      "blockRoles": ["page-header-actions", "breadcrumb-context", "detail-overview", "activity-feed", "comment-thread", "action-footer"],
      "userIntents": ["review", "edit", "browse"],
      "jobMapStages": ["locate", "confirm"],
      "dataShapes": ["single-record", "relational"],
      "interactionModels": ["read-only", "disclosure", "inline-edit"],
      "layoutModel": {
        "shell": "none",
        "region": "full-page",
        "responsive": ["mobile", "desktop"]
      },
      "density": "medium",
      "stateCoverage": ["default", "loading", "empty", "error"],
      "accessibility": {
        "keyboard": true,
        "focusVisible": true,
        "labels": true,
        "contrastChecked": false,
        "notes": "Composed from labelled shadcn/base-ui primitives (breadcrumb nav, labelled record fields, labelled reply control); the composed screen has not received an independent accessibility audit."
      },
      "dependencies": {
        "shadcn": ["alert", "avatar", "badge", "breadcrumb", "button", "button-group", "card", "empty", "field", "item", "separator", "sidebar", "skeleton", "textarea"],
        "npm": ["lucide-react"],
        "registries": ["page-header-actions-01", "breadcrumb-context-01", "detail-overview-01", "activity-feed-01", "comment-thread-01", "action-footer-01"]
      },
      "composition": {
        "requiredBlocks": ["page-header-actions", "breadcrumb-context", "detail-overview", "activity-feed", "comment-thread", "action-footer"],
        "optionalBlocks": ["empty-state", "error-recovery", "loading-skeleton"],
        "incompatibleWith": []
      },
      "verification": {
        "storybookStories": [
          "patterns-detail-detail-01--default",
          "patterns-detail-detail-01--loading",
          "patterns-detail-detail-01--empty",
          "patterns-detail-detail-01--error"
        ],
        "interactionTests": false,
        "accessibilityTests": false,
        "visualSnapshots": false,
        "lintTypecheck": false
      },
      "evidence": {
        "sourceCount": 2,
        "confidence": "medium",
        "verifiedAt": "2026-07-12",
        "sourceUrls": [
          "https://m3.material.io/foundations/layout/canonical-layouts/supporting-pane",
          "https://developer.apple.com/design/human-interface-guidelines/lists-and-tables"
        ]
      },
      "risk": {
        "level": "low",
        "licenseReviewNeeded": false,
        "maintenanceReviewNeeded": false,
        "missingStates": ["permission-denied", "offline", "rtl"],
        "notes": "Record, activity, and comment data are simulated locally with a fixed seed. Edit, approve, reject, and reply actions mutate only local component state; there is no persistence or backend wired in."
      },
      "extensions": {
        "localEvidence": [
          "app/(system)/detail-01/detail-screen.tsx",
          "app/(system)/detail-01/data.json",
          "components/patterns/detail-01-screen.stories.tsx"
        ],
        "taxonomyDecision": "detail presents one primary record plus related context (fields, activity, comments) for review and confirmation, distinct from collection (browsing many records) and create-edit (a form whose primary job is submitting field changes)."
      }
    }
  }
}
