{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "document-workspace-01",
  "type": "registry:block",
  "title": "Document Workspace 01",
  "description": "A long-form document authoring workspace combining an inline-editable document body with in-context comments and file attachments.",
  "categories": ["screen:document-workspace", "intent:edit", "density:low"],
  "registryDependencies": ["alert", "attachment", "avatar", "badge", "breadcrumb", "button", "card", "empty", "field", "input", "scroll-area", "separator", "sidebar", "skeleton", "textarea"],
  "files": [
    {
      "path": "app/document-workspace-01/document-workspace-screen.tsx",
      "type": "registry:component",
      "target": "app/document-workspace-01/document-workspace-screen.tsx"
    },
    {
      "path": "app/document-workspace-01/data.json",
      "type": "registry:file",
      "target": "app/document-workspace-01/data.json"
    }
  ],
  "meta": {
    "aiDesignSystem": {
      "assetKind": "screen-pattern",
      "maturity": "experimental",
      "source": "internal",
      "screenType": "document-workspace",
      "blockRoles": ["page-header-actions", "breadcrumb-context", "document-body-editor", "comment-thread", "file-upload-area"],
      "userIntents": ["edit", "create", "review", "communicate"],
      "jobMapStages": ["locate", "execute", "modify", "conclude"],
      "dataShapes": ["document", "conversation", "media"],
      "interactionModels": ["inline-edit", "real-time", "disclosure", "drag-drop"],
      "layoutModel": {
        "shell": "sidebar",
        "region": "full-page",
        "responsive": ["mobile", "desktop"]
      },
      "density": "low",
      "stateCoverage": ["default", "loading", "empty", "error", "validation-error"],
      "accessibility": {
        "keyboard": true,
        "focusVisible": true,
        "labels": true,
        "contrastChecked": false,
        "notes": "Composed from labelled shadcn/base-ui primitives (breadcrumb nav, labelled document title/body fields, labelled reply and file-remove controls); the composed screen has not received an independent accessibility audit."
      },
      "dependencies": {
        "shadcn": ["alert", "attachment", "avatar", "badge", "breadcrumb", "button", "card", "empty", "field", "input", "scroll-area", "separator", "sidebar", "skeleton", "textarea"],
        "npm": ["lucide-react"],
        "registries": ["page-header-actions-01", "breadcrumb-context-01", "document-body-editor-01", "comment-thread-01", "file-upload-area-01"]
      },
      "composition": {
        "requiredBlocks": ["page-header-actions", "breadcrumb-context", "document-body-editor", "comment-thread", "file-upload-area"],
        "optionalBlocks": ["app-shell-sidebar", "empty-state", "error-recovery", "loading-skeleton"],
        "incompatibleWith": ["app-shell-topnav"]
      },
      "verification": {
        "storybookStories": [
          "patterns-document-workspace-document-workspace-01--default",
          "patterns-document-workspace-document-workspace-01--loading",
          "patterns-document-workspace-document-workspace-01--empty",
          "patterns-document-workspace-document-workspace-01--error",
          "patterns-document-workspace-document-workspace-01--validation-error"
        ],
        "interactionTests": false,
        "accessibilityTests": false,
        "visualSnapshots": false,
        "lintTypecheck": false
      },
      "evidence": {
        "sourceCount": 3,
        "confidence": "low",
        "verifiedAt": "2026-07-12",
        "sourceUrls": [
          "https://www.notion.com/help/writing-and-editing-basics",
          "https://support.google.com/docs/answer/65129",
          "https://support.atlassian.com/confluence-cloud/docs/insert-files-images-and-other-media-into-a-page/"
        ]
      },
      "risk": {
        "level": "medium",
        "licenseReviewNeeded": false,
        "maintenanceReviewNeeded": false,
        "missingStates": ["permission-denied", "offline", "rtl"],
        "notes": "The validation-error state exposes an associated document-title error. Document body, comments, and attachments are simulated locally with a fixed seed. Save, reply, and file-selection actions mutate only local component state; there is no persistence, real-time transport, presence, or conflict resolution wired in."
      },
      "extensions": {
        "localEvidence": [
          "app/document-workspace-01/document-workspace-screen.tsx",
          "app/document-workspace-01/data.json",
          "components/patterns/document-workspace-01-screen.stories.tsx"
        ],
        "taxonomyDecision": "document-workspace's primary job is inline-editing a free-form document body with in-context comments/attachments, unlike detail (read-mostly labelled record fields) and create-edit (discrete validated form fields with submit/cancel)."
      }
    }
  }
}
