{
  "schemaVersion": "0.1.0",
  "appId": "studio-portfolio-01",
  "rootRoute": "/",
  "indexRoute": "/orientation",
  "orientationCompletedRoute": "/overview",
  "deliveryMode": "static-export",
  "layout": {
    "id": "studio-layout",
    "component": "StudioLayout",
    "sidebar": "sidebar-07",
    "appHeader": "page-header-actions-01",
    "appHeaderBehavior": "sticky-top",
    "mobileNavigation": "drawer",
    "navigationGroups": [
      {
        "id": "ai-design-system",
        "label": "AI Design System",
        "itemSource": "primaryNavigation"
      },
      {
        "id": "example-apps",
        "label": "Example Apps",
        "itemSource": "exampleNavigation"
      }
    ],
    "primaryNavigation": [
      { "id": "overview", "label": "Overview", "route": "/overview" },
      { "id": "patterns", "label": "Patterns", "route": "/patterns" },
      { "id": "studio", "label": "Studio", "route": "/studio" },
      { "id": "quality", "label": "Quality", "route": "/quality" },
      { "id": "case-study", "label": "Case Study", "route": "/case-study" }
    ],
    "exampleNavigation": [
      { "id": "ops-pulse", "label": "Ops Pulse", "route": "/examples/ops-pulse" },
      { "id": "member-gate", "label": "Member Gate", "route": "/examples/member-gate" },
      { "id": "invoice-desk", "label": "Invoice Desk", "route": "/examples/invoice-desk" },
      { "id": "launch-board", "label": "Launch Board", "route": "/examples/launch-board" },
      { "id": "review-docs", "label": "Review Docs", "route": "/examples/review-docs" }
    ],
    "utilityNavigation": [
      {
        "id": "settings",
        "label": "Settings",
        "route": "/settings",
        "placement": "sidebar-footer",
        "action": "open-settings-dialog"
      }
    ],
    "windowNavigation": {
      "mode": "in-app-tabs",
      "newWindowLinks": [
        "overview-studio-cta",
        "overview-decision-cta",
        "overview-selected-page-cta",
        "studio-live-preview-cta",
        "studio-pattern-detail-cta",
        "case-study-quality-cta"
      ],
      "childRouteContext": "page-header"
    }
  },
  "exampleApps": {
    "mode": "curated-static",
    "artifactRoot": "studioAppSpec/examples",
    "routeRoot": "/examples",
    "authorship": "top-level-ai",
    "disclosure": "Each example is composed by the top-level AI from the existing inventory. It does not run the golden flow or call an AI service at runtime.",
    "artifactContract": {
      "requiredFiles": [
        "brief.json",
        "flowspec.json",
        "selectionspec.json",
        "buildreport.json"
      ],
      "consistencyKeys": [
        "appId",
        "flowId",
        "stepId",
        "screenType",
        "selectedPattern",
        "implementedRoute"
      ],
      "buildReportPolicy": "Create the BuildReport after the route is implemented. Record pass only for checks that were actually executed successfully."
    },
    "items": [
      {
        "id": "ops-pulse",
        "label": "Ops Pulse",
        "route": "/examples/ops-pulse",
        "previewRoute": "/example-previews/ops-pulse",
        "presentation": "iframe-16-9",
        "brief": "Show the current SaaS operational health, recent movement, and records that need attention in one place.",
        "screenType": "dashboard",
        "selectedPattern": "dashboard-01",
        "requiredBlocks": [
          "app-shell-sidebar",
          "page-header-actions",
          "summary-metric-row",
          "chart-panel",
          "data-table-panel"
        ],
        "primaryInteraction": "Inspect KPIs, trends, and operational records.",
        "dataMode": "static-fixture",
        "implementationStatus": "built"
      },
      {
        "id": "member-gate",
        "label": "Member Gate",
        "route": "/examples/member-gate",
        "brief": "Let a member enter a workspace with email and password or a supported external account.",
        "screenType": "auth",
        "selectedPattern": "login-03",
        "requiredBlocks": ["form-section"],
        "primaryInteraction": "Enter credentials and receive local validation feedback.",
        "dataMode": "local-form-state",
        "implementationStatus": "built",
        "boundary": "No real authentication provider or session is connected."
      },
      {
        "id": "invoice-desk",
        "label": "Invoice Desk",
        "route": "/examples/invoice-desk",
        "previewRoute": "/example-previews/invoice-desk",
        "presentation": "iframe-16-9",
        "brief": "Find invoices quickly, narrow them by status, and inspect the current collection in table or grid form.",
        "screenType": "collection",
        "selectedPattern": "collection-table-01",
        "requiredBlocks": [
          "app-shell-sidebar",
          "page-header-actions",
          "filter-toolbar",
          "data-table-panel"
        ],
        "primaryInteraction": "Search, filter, switch table or grid views, inspect an invoice, and record a session-local payment that updates collections.",
        "dataMode": "static-fixture",
        "implementationStatus": "built",
        "boundary": "No payment processor, accounting connection, or persistence is connected; payment changes are local to the browser session."
      },
      {
        "id": "launch-board",
        "label": "Launch Board",
        "route": "/examples/launch-board",
        "previewRoute": "/example-previews/launch-board",
        "presentation": "iframe-16-9",
        "brief": "Organize release tasks by workflow status and move work forward from planning to completion.",
        "screenType": "planning-board",
        "selectedPattern": "planning-board-01",
        "requiredBlocks": [
          "app-shell-sidebar",
          "page-header-actions",
          "filter-toolbar",
          "board-column"
        ],
        "primaryInteraction": "Move task cards between status columns.",
        "dataMode": "local-seed-state",
        "implementationStatus": "built",
        "boundary": "Card movement is not persisted to a backend."
      },
      {
        "id": "review-docs",
        "label": "Review Docs",
        "route": "/examples/review-docs",
        "brief": "Edit a launch document and keep its review comments and supporting files in the same workspace.",
        "screenType": "document-workspace",
        "selectedPattern": "document-workspace-01",
        "requiredBlocks": [
          "page-header-actions",
          "breadcrumb-context",
          "document-body-editor",
          "comment-thread",
          "file-upload-area"
        ],
        "primaryInteraction": "Edit content, add comments, and manage local attachments.",
        "dataMode": "local-seed-state",
        "implementationStatus": "planned",
        "boundary": "Edits, comments, and files are not persisted or synchronized."
      }
    ]
  },
  "pages": [
    {
      "id": "overview",
      "route": "/overview",
      "uiEntity": "Page",
      "compositionMode": "compose-existing-blocks",
      "composition": "studio-overview-01",
      "contentSource": "docs/examples/*dryrun-saas-ops-01.json + app/flows/dryrun-saas-ops-01/login",
      "blocks": [
        "page-header-actions-01",
        "summary-metric-row-01",
        "detail-overview-01",
        "collection-grid-01"
      ],
      "override": {
        "selectedPattern": "dashboard-01",
        "reason": "The overview first surface is a selectable five-stage system-flow composition. Its concrete authentication example traces one brief through the dryrun-saas-ops-01 FlowSpec, SelectionSpec, and BuildReport into the implemented login-03 UI, demonstrating a ScreenType that the portfolio app itself does not otherwise use."
      }
    },
    {
      "id": "patterns",
      "route": "/patterns",
      "uiEntity": "Page",
      "compositionMode": "reuse-selected",
      "composition": "collection-table-01",
      "contentSource": "registry/*.json",
      "relatedUI": ["pattern-detail", "live-demo"]
    },
    {
      "id": "studio",
      "route": "/studio",
      "uiEntity": "Page",
      "compositionMode": "compose-existing-blocks",
      "composition": "studio-scenario-runner-01",
      "contentSource": "lib/studio-portfolio/studio-scenarios.ts",
      "blocks": [
        "page-header-actions-01",
        "collection-grid-01",
        "detail-overview-01",
        "action-footer-01"
      ],
      "relatedUI": ["result-report", "generated-preview"],
      "override": {
        "selectedPattern": "document-workspace-01",
        "reason": "Static delivery has no runtime FlowSpec/SelectionSpec generator or AI service. A selectable set of transparent prebuilt scenarios demonstrates the complete brief-to-preview relationship without implying generation."
      }
    },
    {
      "id": "quality",
      "route": "/quality",
      "uiEntity": "Page",
      "compositionMode": "compose-existing-blocks",
      "composition": "studio-quality-01",
      "contentSource": "docs/examples/* + registry/*.json",
      "blocks": [
        "page-header-actions-01",
        "summary-metric-row-01",
        "filter-toolbar-01",
        "detail-overview-01",
        "data-table-panel-01"
      ],
      "relatedUI": ["coverage-matrix", "contract-explorer", "provenance-trail"],
      "override": {
        "selectedPattern": "report-analytics-01",
        "reason": "Quality needs to establish traceability and the next inspection action before showing historical checks. Metric cards and a chart do not communicate that purpose."
      }
    },
    {
      "id": "case-study",
      "route": "/case-study",
      "uiEntity": "Page",
      "compositionMode": "compose-existing-blocks",
      "composition": "studio-case-study-01",
      "blocks": [
        "page-header-actions-01",
        "breadcrumb-context-01",
        "detail-overview-01",
        "activity-feed-01"
      ],
      "override": {
        "selectedPattern": "report-analytics-01",
        "reason": "The case study is an editorial document; metric-chart-table regions are a known content-fit mismatch."
      }
    },
    {
      "id": "settings",
      "route": "/settings",
      "uiEntity": "Page",
      "compositionMode": "reuse-selected",
      "composition": "settings-admin-01",
      "blocks": ["settings-section-01"],
      "override": {
        "selectedPattern": "settings-admin-01",
        "reason": "Theme and accent preferences are workspace-level settings. The existing settings-admin screen type and settings-section block fit this controlled static-export surface."
      }
    }
  ],
  "entryPages": [
    {
      "id": "orientation",
      "uiEntity": "Page",
      "route": "/orientation",
      "component": "onboarding-01"
    }
  ],
  "childRoutes": [
    {
      "id": "result-report",
      "parentPage": "studio",
      "route": "/studio/result",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "report-analytics-01",
        "reason": "ChildRouteはSelectionSpec/BuildReportの解決済みstepと採用patternを列挙する要約面であり、metric-chart-table topologyは不要。summary-metric-row-01とdetail blockで構成する。"
      }
    },
    {
      "id": "generated-preview",
      "parentPage": "studio",
      "route": "/studio/preview",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "detail-01",
        "reason": "生成previewはgenerated-preview stepの選定結果をregistry patternとStorybookへ橋渡しするだけの薄い面で、detail-01全体ではなくdetail-overview-01のみ再利用する。"
      }
    },
    {
      "id": "coverage-matrix",
      "parentPage": "quality",
      "route": "/quality/coverage",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "dashboard-01",
        "reason": "coverageはScreenType/blockRoleの在庫マトリクスであり、dashboard-01のchart領域は不要。確認目的とPatternsへの導線を先に置き、summary-metric-row-01は補助情報、tableを判断面として構成する。"
      }
    }
  ],
  "drawers": [
    {
      "id": "pattern-detail",
      "parentPage": "patterns",
      "presentation": "inspector",
      "component": "detail-01"
    },
    {
      "id": "live-demo",
      "parentPage": "patterns",
      "presentation": "preview",
      "component": "selected-pattern-preview",
      "themeBehavior": "follows-resolved-app-theme"
    },
    {
      "id": "ai-assistant",
      "parentPage": "studio",
      "presentation": "wide-assistant",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "conversation-assistant-01",
        "reason": "静的作品では会話履歴を持たないため、conversation-assistant-01のchat topologyではなくai-explainability-label-01とai-prompt-composer-01で不足条件の提示と反映のみを構成する。"
      }
    },
    {
      "id": "selection-rationale",
      "parentPage": "studio",
      "presentation": "comparison",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "report-analytics-01",
        "reason": "rationaleは採用/却下候補・score内訳・前提・riskの比較であり、report-analytics-01のchart領域は不要。card群で構成する。"
      }
    },
    {
      "id": "contract-explorer",
      "parentPage": "quality",
      "presentation": "document-inspector",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "detail-01",
        "reason": "4契約の責務・入出力・実JSONを列挙する文書面で、detail-01全体ではなくdetail-overview-01とpreformatted JSONで構成する。"
      }
    },
    {
      "id": "provenance-trail",
      "parentPage": "quality",
      "presentation": "audit-inspector",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "report-analytics-01",
        "reason": "provenanceは入力digestとregistry digestの監査表示であり、chart領域は不要。detail-overview-01で構成する。"
      }
    }
  ],
  "dialogs": [
    {
      "id": "settings",
      "parentPage": "studio-layout",
      "presentation": "settings-window",
      "compositionMode": "reuse-selected",
      "override": {
        "selectedPattern": "settings-admin-01",
        "reason": "Desktop settings are a focused utility surface. A wide Dialog preserves the current workspace while the settings-admin composition provides a persistent settings navigation."
      }
    },
    {
      "id": "flow-checkpoint",
      "parentPage": "studio",
      "presentation": "approval",
      "compositionMode": "compose-existing-blocks",
      "override": {
        "selectedPattern": "workflow-01",
        "reason": "checkpointは選定結果・resolved step数・既知riskを確認して人間承認へ進む単一Dialogで、workflow-01の多段stepper構造は過剰。detail-overview-01で構成する。"
      }
    }
  ],
  "popovers": [],
  "verification": {
    "requiredCommands": [
      "npm run test:studio-portfolio-data",
      "npm run validate",
      "npm run checks"
    ],
    "requiredViewports": ["mobile", "desktop"],
    "requiredStates": ["default", "loading", "empty", "error"],
    "urlState": {
      "panel": "Drawer or Dialog identifier; opens a transient UI on its owning Page.",
      "pattern": "Pattern identifier used with the Patterns panel.",
      "state": "Verification-only Page state: default, loading, empty, or error."
    }
  }
}
